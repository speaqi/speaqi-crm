{
  "name": "SPEAQI DB Maintenance",
  "nodes": [
    {
      "id": "cron_hourly",
      "name": "Ogni ora",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 2,
      "position": [260, 260],
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyX",
              "value": 60,
              "unit": "minutes"
            }
          ]
        }
      }
    },
    {
      "id": "call_db_maintenance",
      "name": "Run Maintenance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [520, 260],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SPEAQI_CRM_URL + '/api/automation/db-maintenance' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-automation-secret",
              "value": "={{ $env.AUTOMATION_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={}"
      }
    }
  ],
  "connections": {
    "Ogni ora": {
      "main": [
        [
          {
            "node": "Run Maintenance",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  ]
}
