{
  "name": "SPEAQI DB Maintenance",
  "nodes": [
    {
      "id": "cron_hourly",
      "name": "Ogni ora",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [260, 260],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 * * * *"
            }
          ]
        }
      }
    },
    {
      "id": "call_db_maintenance",
      "name": "Run Maintenance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [520, 260],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.APP_BASE_URL + '/api/automation/db-maintenance' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-automation-secret",
              "value": "={{ $env.AUTOMATION_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={}"
      }
    }
  ],
  "connections": {
    "Ogni ora": {
      "main": [
        [
          {
            "node": "Run Maintenance",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "Europe/Rome",
    "executionOrder": "v1"
  },
  "active": false
}
