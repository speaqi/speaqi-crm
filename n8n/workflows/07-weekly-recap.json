{
  "name": "SPEAQI Weekly Recap",
  "nodes": [
    {
      "id": "cron_weekly_recap",
      "name": "Monday 07:30",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        260,
        260
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "30 7 * * 1"
            }
          ]
        }
      }
    },
    {
      "id": "call_weekly_recap_api",
      "name": "Send Weekly Recap",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        520,
        260
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.APP_BASE_URL + '/api/automation/weekly-recap' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-automation-secret",
              "value": "={{ $env.AUTOMATION_SECRET }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"email\":\"{{$env.REMINDER_EMAIL}}\"}"
      }
    }
  ],
  "connections": {
    "Monday 07:30": {
      "main": [
        [
          {
            "node": "Send Weekly Recap",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "Europe/Rome",
    "executionOrder": "v1"
  },
  "active": false
}
