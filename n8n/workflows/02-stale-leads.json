{
  "name": "SPEAQI Stale Leads",
  "nodes": [
    {
      "id": "cron_stale",
      "name": "Every Morning",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        260,
        260
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "call_stale_api",
      "name": "Fetch Stale Leads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        520,
        260
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.APP_BASE_URL + '/api/automation/stale-leads' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-automation-secret",
              "value": "={{ $env.AUTOMATION_SECRET }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"stale_days\":5}"
      }
    }
  ],
  "connections": {
    "Every Morning": {
      "main": [
        [
          {
            "node": "Fetch Stale Leads",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "Europe/Rome",
    "executionOrder": "v1"
  },
  "active": false
}
