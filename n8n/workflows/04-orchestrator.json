{
  "name": "SPEAQI Morning Orchestrator",
  "nodes": [
    {
      "id": "cron_weekday_morning",
      "name": "Lun-Ven 8:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [260, 260],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * 1-5"
            }
          ]
        }
      }
    },
    {
      "id": "call_orchestrator",
      "name": "Run Orchestrator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [520, 260],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SPEAQI_CRM_URL + '/api/automation/orchestrator' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-automation-secret",
              "value": "={{ $env.AUTOMATION_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"days_ahead\":3,\"max_contacts\":50}"
      }
    }
  ],
  "connections": {
    "Lun-Ven 8:00": {
      "main": [
        [
          {
            "node": "Run Orchestrator",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "Europe/Rome",
    "executionOrder": "v1"
  },
  "active": false
}
